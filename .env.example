# Configurações de Ambiente (development / production)
ENVIRONMENT=development

# Configurações do Banco de Dados Relacional (MySQL)
DB_HOST=db
DB_PORT=3306
DB_NAME=restaurante
DB_USER=user
DB_PASSWORD=user_password
DB_ROOT_PASSWORD=root_password
DATABASE_URL=mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Configurações do Banco de Dados NoSQL (MongoDB)
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=mongo_root
MONGO_PASSWORD=mongo_password
MONGO_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/
